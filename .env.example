# Turso (libSQL) — free tier. Used in both dev (locally) and prod.
# Get URL + token from https://turso.tech after creating a database.
DATABASE_URL="libsql://your-db-name.turso.io"
TURSO_TOKEN=""

# Generate with: node -e \"console.log(require('crypto').randomBytes(32).toString('base64'))\"
# Rotate this whenever you suspect it's leaked.
AUTH_SECRET=""

# Set to true when running behind a reverse proxy (Vercel sets this automatically).
# Locally this should remain unset.
AUTH_TRUST_HOST=""

# Canonical URL used in sitemap.xml and OG meta tags.
# Set this to your production domain, e.g. https://shop.example.com
NEXT_PUBLIC_SITE_URL="http://localhost:6969"