# SQLite for local dev. For production, use a managed Postgres and update
# prisma/schema.prisma datasource provider to "postgresql".
DATABASE_URL="file:./dev.db"

# Generate with: openssl rand -base64 32
AUTH_SECRET=""

# Set to true when running behind a reverse proxy (Vercel, nginx, etc.)
# Locally this should remain unset.
AUTH_TRUST_HOST=""

# Canonical URL used in sitemap.xml and OG meta tags.
# Set this to your production domain, e.g. https://shop.example.com
NEXT_PUBLIC_SITE_URL="http://localhost:6969"